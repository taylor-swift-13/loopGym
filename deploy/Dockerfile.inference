# LoopGym — Inference image (testing): vLLM + Frama-C, self-contained.
#
# Deploys a TRAINED model to an in-process vLLM engine and runs inference over a
# set of C programs: generate (vLLM) → optional refine → combine → Houdini →
# Frama-C/WP verify. Inference does not run the reward sampler.
#
# Frama-C + z3 + why3 are bundled, so a GPU host needs no local Frama-C.
# Based on the official vLLM image (CUDA + vLLM already present).
#
# Build (context = repo root):
#   docker build -f deploy/Dockerfile.inference -t loopgym-inference .
# Run (mount the trained model and the test programs):
#   docker run --gpus all --rm \
#     -v /path/to/model:/model -v /path/to/programs:/data \
#     loopgym-inference --model /model --inputs '/data/*.c' --n-rollouts 8 --output /data/out.jsonl
FROM vllm/vllm-openai:latest

ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1

# --- Frama-C/WP + z3 + why3 (real Houdini) ---
# The vLLM image is Ubuntu-based; these live in Ubuntu universe.
RUN apt-get update \
 && apt-get install -y --no-install-recommends frama-c z3 why3 \
 && rm -rf /var/lib/apt/lists/* \
 && ( why3 config detect || why3 config --detect ) \
 && frama-c -version && z3 --version

WORKDIR /app

# --- inference plus shared parser/prompts and Frama-C adapter modules ---
COPY rl_pipeline/__init__.py /app/rl_pipeline/__init__.py
COPY rl_pipeline/common/ /app/rl_pipeline/common/
COPY rl_pipeline/inference/ /app/rl_pipeline/inference/
COPY rl_pipeline/reward/__init__.py rl_pipeline/reward/annotate.py \
     rl_pipeline/reward/filters.py /app/rl_pipeline/reward/

# --- src modules the HoudiniFilter / verifier reuse ---
COPY src/__init__.py src/config.py src/houdini_pruner.py \
     src/output_verify.py src/syntax_checker.py /app/src/
# --- prompts (single source of truth: generate/refine/system) ---
COPY prompt/ /app/prompt/

# Build-time check: inference stays sampler-free and real Houdini is wired.
RUN python3 -c "import sys; \
from rl_pipeline.reward import filters as F; \
assert F.frama_c_available() and F.auto_filter().name.startswith('cascade'), 'frama-c/cascade not wired'; \
import rl_pipeline.inference; \
assert 'rl_pipeline.sampler' not in sys.modules, 'inference imported sampler'; \
print('build OK: independent inference + frama-c cascade + vllm base ready')"

# override the vLLM image's OpenAI-server entrypoint: run our inference CLI.
# args (--model / --inputs / ...) are appended at `docker run`.
ENTRYPOINT ["python3", "-m", "rl_pipeline.inference"]
CMD ["--help"]
